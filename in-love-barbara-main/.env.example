# Copy this file to .env.local and fill the values for your own environment.
# Do not commit .env.local.

# Supabase public browser configuration.
# The anon key is public by design, but keep real project values out of public demos until ready.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Environment
NODE_ENV=development
VITE_APP_ENV=development

# Security/logging
VITE_ENABLE_DEBUG_LOGS=false
VITE_ENABLE_MOCK_AUTH=false

# Production example
# NODE_ENV=production
# VITE_APP_ENV=production
# VITE_ENABLE_DEBUG_LOGS=false
# VITE_ENABLE_MOCK_AUTH=false

# Never add service_role, fiscal API tokens, certificate passwords, admin passwords,
# private keys, or other server-side secrets to VITE_* variables.
